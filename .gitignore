# Runtime state files (not tracked)
.orchestrator.lock
.cycle_count
.browser_server.pid
.session_alert

# Sensitive files
settings.json
.env*

# Browser data
**/browser_data/
**/sessions/_tmp_cookies.db
# Volatile browsr runtime files
**/Singleton*
browser/**/*-wal
browser/**/*-shm

# Python
__pycache__/
*.py[cod]

# Logs
*.log
**/logs/

# OS
.DS_Store

# ignore the system prompt files created for agent from MD
system_prompt.txt
system_prompt_*.txt
